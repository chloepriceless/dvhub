{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "loadpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "mode": { "type": "string", "enum": ["off", "now", "minpv", "pv"] },
          "chargePower": { "type": "number" },
          "chargedEnergy": { "type": "number" },
          "charging": { "type": "boolean" },
          "connected": { "type": "boolean" },
          "enabled": { "type": "boolean" },
          "planActive": { "type": "boolean" },
          "vehicleSoc": { "type": ["number", "null"] },
          "vehicleRange": { "type": ["number", "null"] },
          "minSoc": { "type": "number" },
          "phasesActive": { "type": "number" }
        },
        "required": ["mode", "chargePower", "charging", "connected"]
      }
    },
    "battery": { "type": "array" },
    "grid": { "type": "object" },
    "tariff": { "type": "object" },
    "updatedAt": { "type": "string" }
  },
  "required": ["loadpoints", "updatedAt"]
}
